---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/shared/PageHeader.astro";
import TableOfContents from "@components/shared/TableOfContents.astro";

const tocEntries = [
  { id: "creative-writing", label: "Creative Writing" },
  { id: "popular-science", label: "Popular Science" },
];
---

<BaseLayout
  title="Writing — Indrajeet Patil"
  description="Creative writing and popular science articles by Indrajeet Patil."
>
  <PageHeader
    title="Writing"
    subtitle="Creative fiction and popular science, beyond the peer-reviewed page."
  />

  <div class="mx-auto max-w-5xl px-6 pb-20">
    <!-- Mobile ToC -->
    <div class="reveal mb-8 lg:hidden">
      <TableOfContents entries={tocEntries} variant="inline" />
    </div>

    <div class="lg:flex lg:gap-12">
      <!-- Desktop ToC sidebar -->
      <aside class="hidden lg:block lg:w-48 lg:shrink-0">
        <div class="sticky top-28">
          <TableOfContents entries={tocEntries} variant="sidebar" />
        </div>
      </aside>

      <!-- Main content -->
      <div class="min-w-0 flex-1">
        <!-- Creative Writing -->
        <section class="reveal mb-16" data-toc-section="creative-writing" id="creative-writing">
          <h2 class="mb-6 border-b border-border pb-2 font-serif text-2xl font-bold text-accent">
            Creative Writing
          </h2>
          <div class="space-y-6">
            <article class="rounded-xl border border-border bg-surface p-6 shadow-sm">
              <h3 class="text-lg font-bold text-text">Freezer</h3>
              <p class="mt-1 text-sm font-medium text-accent">Adapted Screenplay</p>
              <p class="mt-3 text-text-muted">
                Adapted from the Marathi short story "Sheetkapat" by Subodh P. Javadekar. Set across three timelines &mdash; a 1960s radio astronomer in West Virginia searching for extraterrestrial signals, a young couple in 2036 Pune facing a catastrophic ice age triggered by Earth's passage through a molecular cloud, and aliens arriving at a frozen Earth in 2215 &mdash; the screenplay weaves together first contact, cryogenic suspended animation, and an intimate love story about whether survival is worth the cost of losing the life you have now.
              </p>
            </article>

            <article class="rounded-xl border border-border bg-surface p-6 shadow-sm">
              <h3 class="text-lg font-bold text-text">Distorted Mirrors: What We're Willing to Lose</h3>
              <p class="mt-1 text-sm font-medium text-education">In Progress</p>
              <p class="mt-3 text-text-muted">
                A collection of fourteen literary speculative fiction stories exploring the fraught relationship between humanity and technology. Set across present-day India, recognizable near-futures, and one far-future outlier, the stories follow ordinary people &mdash; a content moderator in Mumbai processing hate speech, a lonely man who falls in love with an AI companion, an autonomous vehicle haunted by a split-second moral calculation, a domestic worker watching a robot replace her colleague &mdash; as they confront technologies that promise salvation but deliver something far more ambiguous. Organized in three thematic movements (Beautiful Lies, Digital Wounds, Machine Souls), the prose balances literary craftsmanship with accessibility, drawing on influences from Ted Chiang's philosophical precision to Kazuo Ishiguro's understated menace, all filtered through a distinctly Indian literary sensibility.
              </p>
            </article>
          </div>
        </section>

        <!-- Popular Science -->
        <section class="reveal" data-toc-section="popular-science" id="popular-science">
          <h2 class="mb-6 border-b border-border pb-2 font-serif text-2xl font-bold text-accent">
            Popular Science
          </h2>
          <div class="space-y-6">
            <article class="rounded-xl border border-border bg-surface p-6 shadow-sm">
              <h3 class="text-lg font-bold text-text">Popular Science Articles in Marathi</h3>
              <p class="mt-3 text-text-muted">
                A collected volume of popular science articles written in Marathi, making scientific ideas accessible to a broader audience.
              </p>
              <a
                href="/pdfs/writing/marathi_popsci_collected.pdf"
                class="mt-4 inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm font-medium text-cta transition-colors hover:bg-cta/5 hover:text-cta-hover"
                target="_blank"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Download PDF
              </a>
            </article>

            <article class="rounded-xl border border-border bg-surface p-6 shadow-sm">
              <h3 class="text-lg font-bold text-text">
                Research News &mdash; Observation of Exotic Heavy Baryons
              </h3>
              <p class="mt-1 text-sm text-text-muted">
                Ananthanarayan, B., Choudhary, K., Mohapatra, L., Patil, I., Rustagi, A., & Shivaraj, K. (2007)
              </p>
              <p class="mt-2 text-sm text-text-muted">
                A review of the discoveries of exotic heavy baryons at the Fermi National Accelerator Laboratory.
              </p>
              <a
                href="/pdfs/writing/Ananthanarayan_2007_baryons.pdf"
                class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-cta hover:text-cta-hover transition-colors"
                target="_blank"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                PDF
              </a>
            </article>

            <article class="rounded-xl border border-border bg-surface p-6 shadow-sm">
              <h3 class="text-lg font-bold text-text">
                Research News &mdash; Observation of Oscillation Phenomena in Heavy Meson Systems
              </h3>
              <p class="mt-1 text-sm text-text-muted">
                Ananthanarayan, B., Choudhary, K., Mohapatra, L., Patil, I., Rustagi, A., & Shivaraj, K. (2007)
              </p>
              <p class="mt-2 text-sm text-text-muted">
                A review of the discoveries of rare oscillation phenomena in heavy neutral meson systems.
              </p>
              <a
                href="/pdfs/writing/Ananthanarayan_2007_mesons.pdf"
                class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-cta hover:text-cta-hover transition-colors"
                target="_blank"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                PDF
              </a>
            </article>
          </div>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
