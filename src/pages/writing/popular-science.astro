---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/shared/PageHeader.astro";
---

<BaseLayout
  title="Popular Science — Indrajeet Patil"
  description="Popular science articles in Marathi and physics research news."
>
  <PageHeader
    title="Popular Science"
    subtitle="Making science accessible beyond the walls of the academy — in Marathi for a regional readership, and in English for the physics community."
  />

  <div class="mx-auto max-w-3xl px-6 pb-20">
    <!-- Marathi Popular Science -->
    <section class="reveal mb-16">
      <h2 class="mb-6 border-b border-border pb-2 font-serif text-2xl font-bold text-accent">
        Popular Science Articles in Marathi
      </h2>
      <article class="rounded-xl border border-border bg-surface p-6 shadow-sm">
        <p class="text-text-muted">
          A collected volume of popular science articles originally published in
          <a
            href="https://www.loksatta.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-cta hover:text-cta-hover transition-colors"
          >Loksatta</a>, one of India's leading Marathi-language daily newspapers published by the Indian Express Group. With a circulation of approximately 400,000 copies across Maharashtra, Loksatta is widely read by an educated, urban audience. These articles were written in 2011 and aimed to make contemporary scientific ideas accessible to a broader Marathi-speaking readership.
        </p>
        <a
          href="/pdfs/writing/marathi_popsci_collected.pdf"
          class="mt-4 inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm font-medium text-cta transition-colors hover:bg-cta/5 hover:text-cta-hover"
          target="_blank"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Download PDF
        </a>
      </article>
    </section>

    <!-- Research News -->
    <section class="reveal">
      <h2 class="mb-6 border-b border-border pb-2 font-serif text-2xl font-bold text-accent">
        Research News
      </h2>
      <p class="mb-6 text-sm text-text-muted">
        Review articles published in <em>Current Science</em>, the flagship interdisciplinary journal of the Indian Academy of Sciences, summarizing recent discoveries in particle physics for a broad scientific audience.
      </p>
      <div class="space-y-6">
        <article class="rounded-xl border border-border bg-surface p-6 shadow-sm">
          <h3 class="text-lg font-bold text-text">
            Research News &mdash; Observation of Exotic Heavy Baryons
          </h3>
          <p class="mt-1 text-sm text-text-muted">
            Ananthanarayan, B., Choudhary, K., Mohapatra, L., Patil, I., Rustagi, A., &amp; Shivaraj, K. (2007). Research news &mdash; Observation of exotic heavy baryons. <em>Current Science</em>, <em>93</em>(4), 451&ndash;452.
          </p>
          <div class="mt-3 flex flex-wrap gap-3 text-sm">
            <a
              href="/pdfs/writing/Ananthanarayan_2007_baryons.pdf"
              class="inline-flex items-center gap-1 font-medium text-cta hover:text-cta-hover transition-colors"
              target="_blank"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              PDF
            </a>
            <a
              href="https://arxiv.org/abs/0707.4208"
              class="inline-flex items-center gap-1 font-medium text-cta hover:text-cta-hover transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              arXiv:0707.4208
            </a>
          </div>
        </article>

        <article class="rounded-xl border border-border bg-surface p-6 shadow-sm">
          <h3 class="text-lg font-bold text-text">
            Research News &mdash; Observation of Oscillation Phenomena in Heavy Meson Systems
          </h3>
          <p class="mt-1 text-sm text-text-muted">
            Ananthanarayan, B., Choudhary, K., Mohapatra, L., Patil, I., Rustagi, A., &amp; Shivaraj, K. (2007). Research news &mdash; Observation of oscillation phenomena in heavy meson systems. <em>Current Science</em>, <em>93</em>(5), 602&ndash;604.
          </p>
          <div class="mt-3 flex flex-wrap gap-3 text-sm">
            <a
              href="/pdfs/writing/Ananthanarayan_2007_mesons.pdf"
              class="inline-flex items-center gap-1 font-medium text-cta hover:text-cta-hover transition-colors"
              target="_blank"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              PDF
            </a>
            <a
              href="https://arxiv.org/abs/0707.4209"
              class="inline-flex items-center gap-1 font-medium text-cta hover:text-cta-hover transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              arXiv:0707.4209
            </a>
          </div>
        </article>
      </div>
    </section>
  </div>
</BaseLayout>
