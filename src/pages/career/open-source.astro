---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/shared/PageHeader.astro";
import { getCollection } from "astro:content";
import downloadData from "../../../data/download_counts.json";

const allPackages = await getCollection("software");
const packagesData = downloadData.packages as Record<
  string,
  { downloads?: number; downloads_formatted?: string; stars: number }
>;
const totalFormatted = downloadData.total_downloads_formatted;

function getDownloads(name: string): string {
  return packagesData[name]?.downloads_formatted || "—";
}

function getDownloadNum(name: string): number {
  return packagesData[name]?.downloads || 0;
}

function getStars(name: string): number {
  return packagesData[name]?.stars || 0;
}

// Default sort: creators first, then by downloads descending
const defaultSorted = [...allPackages].sort((a, b) => {
  if (a.data.role !== b.data.role) return a.data.role === "creator" ? -1 : 1;
  return getDownloadNum(b.data.name) - getDownloadNum(a.data.name);
});

const categoryLabels: Record<string, string> = {
  "data-visualization": "Data Visualization",
  "data-analysis": "Data Analysis",
  "statistical-reporting": "Statistical Reporting",
  "developer-tools": "Developer Tools",
  utilities: "Utilities",
};
---

<BaseLayout
  title="Open-Source Software — Indrajeet Patil"
  description="Open-source R and Python packages for data analysis, visualization, and developer tooling."
>
  <PageHeader
    title="Open-Source Software"
    subtitle={`Author and maintainer of R and Python packages with ${totalFormatted}+ total downloads. From statistical visualization frameworks used by thousands of researchers to developer tools that help teams write cleaner code, these libraries reflect a core belief: good research software should be as carefully crafted as the research itself.`}
  />

  <div class="mx-auto max-w-6xl px-6 pb-20">
    <!-- Sort controls -->
    <div class="reveal mb-8 flex flex-wrap items-center gap-3">
      <span class="text-sm font-medium text-text-muted">Sort by:</span>
      <div class="flex gap-1" role="toolbar" aria-label="Sort packages" id="sort-controls">
        <button class="sort-btn active rounded-full border border-accent bg-accent px-3 py-1 text-xs font-medium text-white transition-all" data-sort="default">
          Default
        </button>
        <button class="sort-btn rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-text-muted transition-all hover:border-accent/30 hover:text-accent" data-sort="downloads">
          Downloads
        </button>
        <button class="sort-btn rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-text-muted transition-all hover:border-accent/30 hover:text-accent" data-sort="stars">
          Stars
        </button>
        <button class="sort-btn rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-text-muted transition-all hover:border-accent/30 hover:text-accent" data-sort="name">
          Name
        </button>
      </div>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="packages-grid">
      {
        defaultSorted.map((pkg) => (
          <article
            class="reveal group rounded-xl border border-border bg-surface p-5 shadow-sm transition-all hover:shadow-md hover:border-accent/20"
            data-pkg-name={pkg.data.name}
            data-pkg-downloads={getDownloadNum(pkg.data.name)}
            data-pkg-stars={getStars(pkg.data.name)}
            data-pkg-role={pkg.data.role}
          >
            <div class="flex items-start gap-4">
              {/* Hex sticker */}
              {pkg.data.hex_sticker ? (
                <img
                  src={pkg.data.hex_sticker}
                  alt={`${pkg.data.name} hex sticker`}
                  class="h-16 w-16 flex-shrink-0 object-contain"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-lg bg-accent/10 font-serif text-2xl font-bold text-accent">
                  {pkg.data.name.charAt(0).toUpperCase()}
                </div>
              )}

              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <h3 class="truncate font-mono text-lg font-bold text-accent">
                    {pkg.data.name}
                  </h3>
                  {pkg.data.role === "creator" && (
                    <span class="flex-shrink-0 rounded-full bg-accent/10 px-2 py-0.5 text-xs font-medium text-accent">
                      Creator
                    </span>
                  )}
                </div>
                <p class="mt-1 text-sm text-text-muted line-clamp-2">
                  {pkg.data.description}
                </p>
              </div>
            </div>

            {/* Stats row */}
            <div class="mt-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="rounded-full bg-tag-bg px-2.5 py-0.5 text-xs font-medium text-tag-text">
                  {pkg.data.language === "Python" ? "Python" : "R"}
                </span>
                <span class="rounded-full bg-bg-alt px-2.5 py-0.5 text-xs font-medium text-text-muted">
                  {categoryLabels[pkg.data.category]}
                </span>
              </div>
            </div>

            {/* Metrics */}
            <div class="mt-3 flex items-center gap-4 text-sm text-text-muted">
              {getDownloadNum(pkg.data.name) > 0 && (
                <span class="flex items-center gap-1" title="CRAN downloads">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                  </svg>
                  <span class="font-semibold text-accent">{getDownloads(pkg.data.name)}</span>
                </span>
              )}
              {getStars(pkg.data.name) > 0 && (
                <span class="flex items-center gap-1" title="GitHub stars">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                  </svg>
                  <span class="font-semibold">{getStars(pkg.data.name).toLocaleString()}</span>
                </span>
              )}
            </div>

            {/* Links */}
            <div class="mt-3 flex gap-3 border-t border-border pt-3 text-sm">
              {pkg.data.cran_url && (
                <a href={pkg.data.cran_url} target="_blank" rel="noopener noreferrer" class="font-medium text-cta hover:text-cta-hover transition-colors">
                  CRAN
                </a>
              )}
              {pkg.data.pypi_url && (
                <a href={pkg.data.pypi_url} target="_blank" rel="noopener noreferrer" class="font-medium text-cta hover:text-cta-hover transition-colors">
                  PyPI
                </a>
              )}
              <a href={pkg.data.github_url} target="_blank" rel="noopener noreferrer" class="font-medium text-cta hover:text-cta-hover transition-colors">
                GitHub
              </a>
              {pkg.data.docs_url && (
                <a href={pkg.data.docs_url} target="_blank" rel="noopener noreferrer" class="font-medium text-cta hover:text-cta-hover transition-colors">
                  Docs
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>

    <p class="mt-8 text-center text-xs text-text-muted">
      Download counts from CRAN and PyPI, last updated {new Date(downloadData.updated_at).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}.
    </p>
  </div>
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const grid = document.getElementById("packages-grid");
    const buttons = document.querySelectorAll("#sort-controls .sort-btn");
    if (!grid) return;

    function sortGrid(sortBy: string) {
      const cards = [...grid!.querySelectorAll("article")] as HTMLElement[];

      cards.sort((a, b) => {
        if (sortBy === "downloads") {
          return (Number(b.dataset.pkgDownloads) || 0) - (Number(a.dataset.pkgDownloads) || 0);
        }
        if (sortBy === "stars") {
          return (Number(b.dataset.pkgStars) || 0) - (Number(a.dataset.pkgStars) || 0);
        }
        if (sortBy === "name") {
          return (a.dataset.pkgName || "").localeCompare(b.dataset.pkgName || "");
        }
        // default: creators first, then downloads
        if (a.dataset.pkgRole !== b.dataset.pkgRole) {
          return a.dataset.pkgRole === "creator" ? -1 : 1;
        }
        return (Number(b.dataset.pkgDownloads) || 0) - (Number(a.dataset.pkgDownloads) || 0);
      });

      cards.forEach((card) => grid!.appendChild(card));
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        buttons.forEach((b) => {
          b.classList.remove("active", "border-accent", "bg-accent", "text-white");
          b.classList.add("border-border", "bg-surface", "text-text-muted");
        });
        btn.classList.add("active", "border-accent", "bg-accent", "text-white");
        btn.classList.remove("border-border", "bg-surface", "text-text-muted");
        sortGrid((btn as HTMLElement).dataset.sort || "default");
      });
    });
  });
</script>
