---
import PageHeader from "@components/shared/PageHeader.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const roles = [
  {
    title: "Senior Software Engineer",
    org: "Carl Zeiss AG",
    logo: "/images/logos/zeiss.svg",
    location: "Munich, Germany",
    period: "Jan 2025 — Present",
    description: [
      "Led development of the foundational template that serves as the starting point for every business application on ZEISS's Generative AI platform, establishing cross-unit development standards and delivering an estimated €1.3M in value through accelerated deployment cycles (Python/TypeScript/Terraform).",
      "Led the implementation of the AI Launchpad, a centralized enterprise platform for tracking the state of AI across ZEISS, adopted company-wide and used by senior leadership — including the CFO and CEO — to monitor AI progress.",
      "Led the technical design and implementation of Debrief Expert Copilot, an LLM-powered knowledge management system that tackles the critical business challenge of preserving institutional knowledge when senior experts retire or leave the company.",
      "Authored a comprehensive internal book on agentic engineering, guiding ZEISS software teams on adopting AI coding agents effectively in enterprise development, covering tool selection, compliance, security, context management, and custom agent development.",
    ],
  },
  {
    title: "Senior Software Engineer",
    org: "Preisenergie",
    logo: "/images/logos/preisenergie.png",
    location: "Munich, Germany",
    period: "Oct 2023 — Dec 2024",
    description: [
      "Architected and delivered scalable browser-based full-stack applications (FastAPI/Next.js/React) serving the German energy market with high availability and performance requirements.",
      "Led infrastructure modernization, orchestrating microservices architecture in Kubernetes clusters through automated CI/CD pipelines (CircleCI, ArgoCD).",
      "Principal architect and technical lead for full-stack Shiny applications ecosystem, R package development, and mission-critical ETL pipeline infrastructure, transforming previously unmaintainable legacy systems into well-structured, developer-friendly codebases.",
      "Orchestrated comprehensive cloud migration strategy, successfully transitioning all company applications from AWS to GCP with zero downtime.",
    ],
  },
  {
    title: "Senior Research Software Engineer",
    org: "esqLABS",
    logo: "/images/logos/esqlabs.png",
    location: "Berlin, Germany",
    period: "Sep 2021 — Aug 2022",
    description: [
      "Led technical implementation of advanced PBPK modelling, simulation, and visualisation systems using sophisticated object-oriented design patterns and architectural principles.",
      "Drove feature development and quality assurance for production full-stack Shiny web applications in the pharmacometrics domain, ensuring robust testing frameworks and production reliability.",
      "Designed and architected comprehensive modular R package ecosystem, establishing scalable software architecture to enhance long-term maintainability and extensibility.",
    ],
  },
];
---

<BaseLayout
  title="Industry Career — Indrajeet Patil"
  description="Industry career timeline as a software engineer across optics, energy, analytics, and pharma."
>
  <PageHeader
    title="Industry"
    subtitle="After a decade in academia, I transitioned into industry software engineering — drawn not away from research, but toward a different kind of problem-solving. Each role has deepened my conviction that the best engineering comes from genuinely understanding the domain you're building for."
  />

  <div class="mx-auto max-w-4xl px-6 pb-20">
    <div class="relative">
      <!-- Vertical line -->
      <div
        class="absolute left-6 top-0 bottom-0 w-0.5 bg-border sm:left-8"
        aria-hidden="true"
      ></div>

      <div class="space-y-12">
        {
          roles.map((role, i) => (
            <div class="reveal relative flex gap-6 sm:gap-8" style={`transition-delay: ${i * 0.08}s`}>
              {/* Dot */}
              <div class="relative z-10 flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full border-2 border-border bg-surface shadow-sm sm:h-16 sm:w-16">
                {role.logo ? (
                  <img src={role.logo} alt={role.org} class="h-8 w-8 object-contain sm:h-10 sm:w-10" />
                ) : (
                  <span class="text-lg font-bold text-accent sm:text-xl">
                    {role.org.charAt(0)}
                  </span>
                )}
              </div>

              {/* Content */}
              <div class="flex-1 rounded-xl border border-border bg-surface p-5 shadow-sm transition-shadow hover:shadow-md sm:p-6">
                <span class="inline-block rounded-full bg-work/10 px-2.5 py-0.5 text-xs font-medium text-work">
                  {role.period}
                </span>
                <h3 class="mt-2 text-lg font-bold text-text">{role.title}</h3>
                <p class="text-sm font-medium text-accent">{role.org}</p>
                <p class="text-xs text-text-muted">{role.location}</p>

                <ul class="mt-4 space-y-2">
                  {role.description.map((item) => (
                    <li class="flex gap-2 text-sm text-text-muted">
                      <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-work/40" aria-hidden="true" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>
