---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/shared/PageHeader.astro";

const positions = [
  {
    title: "Postdoctoral Fellow",
    org: "Max Planck Institute for Human Development",
    location: "Berlin, Germany",
    period: "2019 - 2021",
    advisor: "Iyad Rahwan",
    description:
      "Investigated computational models of moral behavior and moral cognition using large-scale behavioral experiments, machine learning approaches, and agent-based simulations. Explored how people make moral judgments and how these judgments can be modeled algorithmically.",
  },
  {
    title: "Postdoctoral Fellow",
    org: "Harvard University",
    department: "Department of Psychology",
    location: "Cambridge, MA, USA",
    period: "2017 - 2019",
    advisor: "Mina Cikara and Fiery Cushman",
    description:
      "Studied moral cognition using a combination of behavioral experiments, functional neuroimaging (fMRI), and computational modeling. Investigated how reasoning supports utilitarian moral judgments, the neural basis of empathic blame, and reputational benefits of third-party punishment.",
  },
  {
    title: "Visiting Researcher",
    org: "SISSA",
    logo: "/images/logos/sissa.png",
    location: "Trieste, Italy",
    period: "2016",
    advisor: "Giorgia Silani",
    description:
      "Conducted collaborative research on the neuroanatomical basis of concern-based altruism using virtual reality paradigms and structural MRI analysis.",
  },
];

const education = [
  {
    degree: "Doctor of Philosophy (Neuroscience)",
    org: "SISSA",
    logo: "/images/logos/sissa.png",
    location: "Trieste, Italy",
    period: "2011 - 2015",
    distinction: "Summa cum laude",
    advisor: "Giorgia Silani",
    thesis: "A multimodal investigation of moral decision making in harmful contexts",
  },
  {
    degree: "Master of Science (Physics)",
    org: "University of Pune",
    location: "Pune, India",
    period: "2008 - 2010",
    thesis: "Effect of hypergravity on amylase and total protein content in germinating rice seeds",
  },
  {
    degree: "Bachelor of Science (Physics)",
    org: "Fergusson College",
    location: "Pune, India",
    period: "2005 - 2008",
    distinction: "Satish Bhide Prize for the Best Undergraduate Thesis",
    thesis: "Theoretical studies of static friction at atomic scale for unlubricated BCC solids",
  },
];

const researchLines = [
  {
    title: "Moral Cognition and Decision-Making",
    description:
      "My primary research program investigated how people make moral judgments — why we condemn some harmful actions but excuse others, how reasoning and emotion interact in moral evaluation, and what neural systems underpin these processes. Using fMRI, psychophysiology, and behavioral experiments, I showed that deliberative reasoning supports utilitarian moral judgments across diverse measures, and that empathy plays divergent roles in judgments of blame versus forgiveness.",
    tags: ["fMRI", "Psychophysiology", "Behavioral experiments", "Computational modeling"],
  },
  {
    title: "Individual Differences in Moral Judgment",
    description:
      "A parallel line of work examined how clinical and subclinical traits — alexithymia, psychopathy, autism, anxiety, and multiple sclerosis — modulate moral decision-making. This research revealed that reduced empathic concern leads to more utilitarian judgments, while autistic and alexithymic traits have divergent effects on moral evaluation.",
    tags: ["Clinical psychology", "Individual differences", "Psychometrics"],
  },
  {
    title: "Open-Source Statistical Software",
    description:
      "Throughout my academic career, I developed open-source statistical tools to address methodological gaps I encountered in my own research. This led to ggstatsplot for informative statistical visualizations, the easystats ecosystem for unified model analysis, and contributions to code quality tools like lintr and styler.",
    tags: ["R programming", "Data visualization", "Software engineering"],
  },
];
---

<BaseLayout
  title="Research Career — Indrajeet Patil"
  description="Research career spanning cognitive neuroscience, moral psychology, and statistical computing."
>
  <PageHeader
    title="Research"
    subtitle="A decade of research at the intersection of neuroscience, moral psychology, and computational methods — investigating how humans navigate ethical dilemmas, and building the statistical tools to study these questions rigorously."
  />

  <div class="mx-auto max-w-4xl px-6 pb-20">
    <!-- Research Lines -->
    <section class="reveal mb-16">
      <h2 class="mb-8 border-b border-border pb-2 font-serif text-2xl font-bold text-accent">
        Research Lines
      </h2>
      <div class="space-y-8">
        {
          researchLines.map((line) => (
            <article class="rounded-xl border border-border bg-surface p-6 shadow-sm">
              <h3 class="text-lg font-bold text-text">{line.title}</h3>
              <p class="mt-3 text-text-muted">{line.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {line.tags.map((tag) => (
                  <span class="rounded-full bg-tag-bg px-2.5 py-0.5 text-xs font-medium text-tag-text">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
      <p class="mt-6 text-sm text-text-muted">
        For the full list of publications, see <a href="/publications" class="font-medium text-cta hover:text-cta-hover transition-colors">Publications</a>.
      </p>
    </section>

    <!-- Positions -->
    <section class="reveal mb-16">
      <h2 class="mb-8 border-b border-border pb-2 font-serif text-2xl font-bold text-accent">
        Research Positions
      </h2>
      <div class="space-y-6">
        {
          positions.map((pos) => (
            <article class="flex gap-4 rounded-xl border border-border bg-surface p-5 shadow-sm sm:gap-6">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full border border-border bg-bg sm:h-14 sm:w-14">
                {pos.logo ? (
                  <img src={pos.logo} alt={pos.org} class="h-8 w-8 object-contain sm:h-9 sm:w-9" />
                ) : (
                  <span class="text-lg font-bold text-research">{pos.org.charAt(0)}</span>
                )}
              </div>
              <div>
                <span class="inline-block rounded-full bg-research/10 px-2.5 py-0.5 text-xs font-medium text-research">
                  {pos.period}
                </span>
                <h3 class="mt-1 text-lg font-bold text-text">{pos.title}</h3>
                <p class="text-sm font-medium text-accent">{pos.org}</p>
                {pos.department && <p class="text-xs text-text-muted">{pos.department}</p>}
                <p class="text-xs text-text-muted">{pos.location}</p>
                {pos.advisor && (
                  <p class="mt-1 text-xs text-text-muted">
                    Advisor: {pos.advisor}
                  </p>
                )}
                <p class="mt-3 text-sm text-text-muted">{pos.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Education -->
    <section class="reveal">
      <h2 class="mb-8 border-b border-border pb-2 font-serif text-2xl font-bold text-accent">
        Education
      </h2>
      <div class="space-y-6">
        {
          education.map((edu) => (
            <article class="flex gap-4 rounded-xl border border-border bg-surface p-5 shadow-sm sm:gap-6">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full border border-border bg-bg sm:h-14 sm:w-14">
                {edu.logo ? (
                  <img src={edu.logo} alt={edu.org} class="h-8 w-8 object-contain sm:h-9 sm:w-9" />
                ) : (
                  <span class="text-lg font-bold text-education">{edu.org.charAt(0)}</span>
                )}
              </div>
              <div>
                <span class="inline-block rounded-full bg-education/10 px-2.5 py-0.5 text-xs font-medium text-education">
                  {edu.period}
                </span>
                <h3 class="mt-1 text-lg font-bold text-text">{edu.degree}</h3>
                <p class="text-sm font-medium text-accent">{edu.org}</p>
                <p class="text-xs text-text-muted">{edu.location}</p>
                {edu.distinction && (
                  <p class="mt-1 text-xs font-medium text-education">{edu.distinction}</p>
                )}
                {edu.advisor && (
                  <p class="mt-1 text-xs text-text-muted">Advisor: {edu.advisor}</p>
                )}
                {edu.thesis && (
                  <p class="mt-2 text-sm italic text-text-muted">Thesis: {edu.thesis}</p>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
