---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = "/favicon.svg" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Indrajeet Patil" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(ogImage, Astro.site)} />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
<meta name="twitter:creator" content="@patilindrajeets" />

<!-- JSON-LD Person Schema (homepage only) -->
{
  Astro.url.pathname === "/" && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Indrajeet Patil",
        url: "https://indrajeetpatil.github.io",
        jobTitle: "Senior Software Engineer",
        worksFor: { "@type": "Organization", name: "Carl Zeiss AG" },
        sameAs: [
          "https://github.com/IndrajeetPatil",
          "https://www.linkedin.com/in/indrajeet-patil-397865174/",
          "https://scholar.google.co.in/citations?user=kBjhJPcAAAAJ",
          "https://twitter.com/patilindrajeets",
        ],
      })}
    />
  )
}
