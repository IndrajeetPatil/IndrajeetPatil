---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mx-auto max-w-6xl px-6 py-16 text-center">
  <h1 class="font-serif text-4xl font-bold tracking-tight text-accent sm:text-5xl">
    {title}
  </h1>
  {subtitle && <p class="mx-auto mt-4 max-w-2xl text-lg text-text-muted">{subtitle}</p>}
</div>
