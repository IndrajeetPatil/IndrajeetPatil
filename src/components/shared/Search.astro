---
// Pagefind search component — indexes the built site at build time
---

<div class="search-container" id="search-container">
  <button
    id="search-btn"
    class="flex items-center gap-2 rounded-lg border border-border bg-surface px-3 py-1.5 text-sm text-text-muted transition-colors hover:border-accent/30 hover:text-accent"
    aria-label="Search the site"
  >
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
    <span class="hidden sm:inline">Search</span>
    <kbd class="hidden rounded border border-border px-1.5 py-0.5 text-xs font-mono text-text-muted sm:inline">/</kbd>
  </button>
</div>

<!-- Search modal -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden">
  <div class="absolute inset-0 bg-text/40 backdrop-blur-sm" id="search-overlay"></div>
  <div class="relative mx-auto mt-[10vh] max-w-2xl px-4">
    <div id="search-widget" class="rounded-xl border border-border bg-surface shadow-2xl"></div>
  </div>
</div>

<style is:global>
  /* Pagefind UI overrides to match the site theme */
  .pagefind-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #034f46;
    --pagefind-ui-text: #1a1a2e;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e2e8f0;
    --pagefind-ui-tag: #f0fdfa;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: "Inter", system-ui, sans-serif;
  }

  .pagefind-ui .pagefind-ui__search-input {
    font-weight: 500;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: #034f46;
  }

  .pagefind-ui .pagefind-ui__result-link:hover {
    color: #0d9488;
  }

  /* Dark mode overrides */
  .dark .pagefind-ui {
    --pagefind-ui-primary: #2dd4bf;
    --pagefind-ui-text: #e8edf4;
    --pagefind-ui-background: #1c2a3f;
    --pagefind-ui-border: #2a3a52;
    --pagefind-ui-tag: #0d3d38;
  }

  .dark .pagefind-ui .pagefind-ui__result-link {
    color: #2dd4bf;
  }

  .dark .pagefind-ui .pagefind-ui__result-link:hover {
    color: #5eead4;
  }
</style>

<script>
  let pagefindLoaded = false;

  async function openSearch() {
    const modal = document.getElementById("search-modal");
    modal?.classList.remove("hidden");

    if (!pagefindLoaded) {
      // Dynamically load Pagefind UI
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = "/pagefind/pagefind-ui.css";
      document.head.appendChild(link);

      // Pagefind is only available after a production build — construct the path
      // dynamically so Vite's import analysis doesn't try to resolve it in dev.
      const pagefindPath = ["/pagefind", "pagefind-ui.js"].join("/");
      // @ts-ignore
      const pagefind = await import(/* @vite-ignore */ pagefindPath);
      new pagefind.PagefindUI({
        element: "#search-widget",
        showSubResults: true,
        showImages: false,
      });
      pagefindLoaded = true;
    }

    // Focus the search input
    setTimeout(() => {
      const input = document.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
      input?.focus();
    }, 100);
  }

  function closeSearch() {
    document.getElementById("search-modal")?.classList.add("hidden");
  }

  // Button click
  document.getElementById("search-btn")?.addEventListener("click", openSearch);

  // Overlay click to close
  document.getElementById("search-overlay")?.addEventListener("click", closeSearch);

  // Keyboard shortcuts
  document.addEventListener("keydown", (e) => {
    if (e.key === "/" && !["INPUT", "TEXTAREA"].includes((e.target as HTMLElement)?.tagName)) {
      e.preventDefault();
      openSearch();
    }
    if (e.key === "Escape") {
      closeSearch();
    }
  });
</script>
