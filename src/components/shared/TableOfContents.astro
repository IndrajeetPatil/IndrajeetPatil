---
interface TocEntry {
  id: string;
  label: string;
}

interface Props {
  entries: TocEntry[];
  variant?: "sidebar" | "inline";
}

const { entries, variant = "sidebar" } = Astro.props;
---

{
  variant === "inline" ? (
    <nav class="flex gap-2 overflow-x-auto rounded-lg border border-border bg-surface p-2" aria-label="Table of contents" style="scrollbar-width: none;">
      {entries.map((entry) => (
        <a
          href={`#${entry.id}`}
          class="toc-link flex-shrink-0 rounded-md px-3 py-1.5 text-sm font-medium text-text-muted transition-colors hover:bg-accent/5 hover:text-accent"
          data-toc-id={entry.id}
        >
          {entry.label}
        </a>
      ))}
    </nav>
  ) : (
    <nav aria-label="Table of contents">
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-text-muted">
        On this page
      </p>
      <ul class="space-y-1" role="list">
        {entries.map((entry) => (
          <li>
            <a
              href={`#${entry.id}`}
              class="toc-link block border-l-2 border-border py-1 pl-3 text-sm text-text-muted hover:text-accent hover:border-accent transition-colors"
              data-toc-id={entry.id}
            >
              {entry.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  nav[style*="scrollbar-width"]::-webkit-scrollbar {
    display: none;
  }
  .toc-link.active {
    color: var(--color-accent);
  }
  nav:not([style]) .toc-link.active {
    border-left-color: var(--color-accent);
  }
  nav[style] .toc-link.active {
    background-color: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }
</style>

<script>
  function initToc() {
    const sections = document.querySelectorAll("[data-toc-section]");
    const tocLinks = document.querySelectorAll("[data-toc-id]");
    if (!sections.length || !tocLinks.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = (entry.target as HTMLElement).getAttribute("data-toc-section");
            tocLinks.forEach((link) => {
              link.classList.toggle("active", link.getAttribute("data-toc-id") === id);
            });
          }
        }
      },
      { rootMargin: "-80px 0px -60% 0px", threshold: 0 },
    );

    sections.forEach((section) => observer.observe(section));
  }

  initToc();
  document.addEventListener("astro:page-load", initToc);
</script>
